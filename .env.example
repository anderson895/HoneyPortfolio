# --- Cloudinary ---------------------------------------------------------------
# Copy this file to ".env" and fill in your real values.
# Find them on your Cloudinary Dashboard: https://console.cloudinary.com

# Used at BUILD TIME by the site to construct image/video URLs (must be VITE_*).
# This is the only value that ends up in the deployed front-end. Safe to expose.
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Used ONLY by scripts/upload-to-cloudinary.mjs to upload your media.
# KEEP THESE SECRET — never commit them and never prefix them with VITE_.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
